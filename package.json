{
  "name": "glucose-cgm",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "nightscout:up": "docker compose -f docker-compose.nightscout.yml up -d",
    "nightscout:libre": "docker compose -f docker-compose.nightscout.yml --profile libre up -d",
    "nightscout:down": "docker compose -f docker-compose.nightscout.yml down",
    "nightscout:logs": "docker compose -f docker-compose.nightscout.yml logs -f nightscout",
    "libre:logs": "docker compose -f docker-compose.nightscout.yml logs -f libreview-sync"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
