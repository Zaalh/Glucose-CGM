LIBREVIEW_EMAIL=mail@example.com
LIBREVIEW_PASSWORD=your-libreview-password
# Tijdzone: standaard DST-automatiek via LIBREVIEW_TZ (zomer/winter klopt vanzelf).
LIBREVIEW_TZ=Europe/Amsterdam
# LIBREVIEW_TZ_OFFSET alleen invullen als je een VASTE offset wilt forceren (geen DST).
# Leeg laten = automatisch. (Vaste 120 liep in de winter een uur fout.)
# LIBREVIEW_TZ_OFFSET=
LIBREVIEW_INTERVAL_SECONDS=60
LIBREVIEW_GRACE_WINDOW_MINUTES=30
LIBREVIEW_RETRY_ATTEMPTS=6
LIBREVIEW_RETRY_BASE_DELAY_MS=1200
LIBREVIEW_RETRY_MAX_DELAY_MS=20000
LIBREVIEW_HTTP_TIMEOUT_MS=15000
LIBREVIEW_RETRY_JITTER_MS=400

# Optionele AI-laag (standaard uit). Alleen officiële OpenAI-compatible /v1/chat/completions endpoints.
# Wordt alleen gebruikt door `npm run ai:review`; nooit voor live alarmbeslissingen.
# Nieuwe router-config: volgorde = fallback-volgorde.
# AI_ROUTER_PROVIDERS=openai,zai
# AI_OPENAI_BASE_URL=https://api.openai.com
# AI_OPENAI_API_KEY=your-openai-api-key
# AI_OPENAI_MODEL=gpt-4.1-mini
# AI_ZAI_BASE_URL=https://api.z.ai
# AI_ZAI_API_KEY=your-zai-api-key
# AI_ZAI_MODEL=glm-4.5
#
# Legacy single-provider config blijft werken als AI_ROUTER_PROVIDERS leeg is.
# AI_CHAT_BASE_URL=https://api.example.com
# AI_CHAT_API_KEY=your-ai-api-key
# AI_CHAT_MODEL=gpt-4.1-mini
# AI_REVIEW_LIMIT=24
# AI_CHAT_TIMEOUT_MS=30000
