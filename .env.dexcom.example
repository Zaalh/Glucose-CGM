DEXCOM_USERNAME=your-dexcom-username
DEXCOM_PASSWORD=your-dexcom-password
# Europe/Outside-US Dexcom Share. Gebruik "us" voor Verenigde Staten.
DEXCOM_REGION=ous
# Dexcom Share levert normaal elke 5 minuten een punt; 288 punten = 24 uur.
DEXCOM_MINUTES=1440
DEXCOM_MAX_COUNT=288
# Optioneel: expliciete ShareWebServices base URL als de regio-default niet werkt.
# DEXCOM_BASE_URL=https://shareous1.dexcom.com/ShareWebServices/Services
